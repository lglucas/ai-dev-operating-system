# PetReceita — .env.example
# Copia pra .env (que NUNCA vai pro repo) e preenche com valores reais.

# === Supabase (project) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...placeholder-public-key

# === Supabase (server-only) ===
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...placeholder-service-role-NEVER-COMMIT

# === Resend (envio de email com receita) ===
RESEND_API_KEY=re_placeholder_your_key_here
RESEND_FROM_EMAIL=receitas@petreceita.com.br

# === ICP-Brasil A3 (assinatura digital da receita) ===
# Provedor a definir após Stage 11.5 (Registry pick): Bry, ITTRU, ValidCertificadora
ICP_PROVIDER=bry
ICP_API_KEY=placeholder_provider_api_key
ICP_CERT_PATH=/path/to/cert.pfx

# === Telemetria (opcional, fase 2) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
