# course/systems/.env.example
# Copia este arquivo pra .env (que NUNCA vai pro repo) e preenche com valores reais.
# IMPORTANTE: este arquivo público só tem placeholders. .env real vive APENAS local
# e nas Settings -> Edge Functions -> Secrets da Supabase.

# === Public (vão pro HTML, é seguro) ===
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbG...placeholder-public-key

# === Privado (apenas Edge Function, NUNCA no repo) ===
# Configurar via Supabase Dashboard -> Settings -> Edge Functions -> Secrets
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...placeholder-service-role
GITHUB_PAT=ghp_placeholder_personal_access_token_with_public_repo_scope
