# ===================================================================
# .env.example — AI Dev Operating System
#
# This file lists every environment variable a project derived from
# this OS may need. Copy it to `.env` (or `.env.local`) and fill in
# real values. NEVER commit `.env` files. The `.gitignore` already
# blocks them.
#
# Vibe coder rules:
#   1. If a variable holds a secret, treat it like a credit card.
#   2. If you don't know what something does, ask Claude before
#      pasting a real value.
#   3. Free-tier defaults below; upgrade only when you have users.
# ===================================================================

# --- Project identity ----------------------------------------------
PROJECT_NAME=my-saas
PROJECT_ENV=development          # development | staging | production
PROJECT_URL=http://localhost:3000

# --- AI providers (only fill what you actually use) ----------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- Database (Supabase by default) --------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # SECRET — server-side only

# --- Auth ----------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                 # generate: openssl rand -base64 32

# --- Email (transactional) -----------------------------------------
RESEND_API_KEY=
EMAIL_FROM=hello@example.com

# --- Payments (Stripe) ---------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Storage / files -----------------------------------------------
# UPLOADTHING_SECRET=
# UPLOADTHING_APP_ID=

# --- Analytics / monitoring ----------------------------------------
# POSTHOG_KEY=
# SENTRY_DSN=

# --- Feature flags / debug -----------------------------------------
DEBUG=false
LOG_LEVEL=info                   # debug | info | warn | error
